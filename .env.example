# Required
SECRET_KEY=change-me-in-production

# Bank sync — Pluggy (https://pluggy.ai)
## 1. Create an account at https://dashboard.pluggy.ai
## 2. Copy your Client ID and Client Secret
## 3. Add http://localhost:${FRONTEND_PORT}/oauth/callback as an allowed redirect URI
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# Bank sync — Enable Banking (https://enablebanking.com) for European banks
## 1. Sign up at https://enablebanking.com and create a Production application
## 2. Add http://localhost:${FRONTEND_PORT}/oauth/callback as an allowed redirect URL
## 3. Save the downloaded PEM file to ./secrets/enable_banking_private.pem
## 4. Copy your Application ID below
ENABLE_BANKING_APP_ID=
# Override only if you put the PEM somewhere other than the default below
# ENABLE_BANKING_PRIVATE_KEY_FILE=/app/secrets/enable_banking_private.pem
# Must match exactly one of the Allowed Redirect URLs in your EB application
ENABLE_BANKING_OAUTH_REDIRECT_URI=http://localhost:${FRONTEND_PORT:-3000}/oauth/callback

# Host ports (optional) — change these to avoid conflicts with other services
## Default values are set in docker-compose.yml and docker-compose.prod.yml.
## Example:
# FRONTEND_PORT=3132
# BACKEND_PORT=8182

# AI Agents (optional) — to enable, set BOTH:
#   1) the feature flag
#   2) COMPOSE_PROFILES so `docker compose up` starts the mcp-server container
# AGENTS_ENABLED=true
# COMPOSE_PROFILES=agents

# Traefik / reverse-proxy deploy (docker-compose.prod.yml)
## The app (frontend) and the MCP server are served through Traefik on the
## external `proxy` network using entrypoint `websecure` + certresolver `le`.
## Point these at the hostnames that resolve to your server.
SECURO_DOMAIN=securo.pipedocs.app
## Subdomain for the built-in MCP server (only used when the `agents` profile
## is on). This is the URL your Hermes agent connects to: https://<host>/mcp
SECURO_MCP_DOMAIN=mcp-securo.pipedocs.app
## Public base URL of the app — used for OAuth redirects / links. Should match
## SECURO_DOMAIN over HTTPS in production.
FRONTEND_URL=https://securo.pipedocs.app